# Postgres connection string
DATABASE_URL="postgresql://vestra:vestra@localhost:5432/vestra?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Auth — JWT_SECRET must be 32+ chars. Server refuses to start otherwise.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="replace-with-32plus-char-random-string-generated-securely"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# CORS (comma-separated for multiple origins)
CORS_ORIGIN="http://localhost:5173"

# Rate limit — general
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Rate limit — auth endpoints (stricter to block brute force)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Seed guard — only set true if you intentionally want to seed a prod DB
# ALLOW_SEED=false
# SEED_PASSWORD=changeme
